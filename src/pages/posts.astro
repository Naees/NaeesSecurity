---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import { site } from '../data/site';
import { formatDate, getBaseUrl, getReadingTime, resolveAssetPath } from '../lib/utils';

const base = getBaseUrl(import.meta.env.BASE_URL);
const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();
---

<Layout title={`${site.blogName} — notes archive`} description={`${site.blogName}: essays, security notes, and technical writing by Naees.`} pathname="/posts/" pageClass="blog-page" showScrollProgress>
  <section class="page-hero shell">
    <p class="eyebrow">{site.blogName}</p>
    <h1>Exposing the <span class="unseen-word">unseen</span>.</h1>
    <p class="lede">Security research, technical findings, and field notes from the NaeesSecurity desk.</p>
  </section>

  <section class="shell archive-controls" aria-label="Post search and filters">
    <label class="archive-search">
    <span>Search posts</span>
      <input data-post-search type="search" placeholder="Search title, description, or tag…" autocomplete="off" />
    </label>

    <div class="tag-filter" aria-label="Filter by tags">
      {tags.map((tag) => (
        <button type="button" class="tag-filter__button" data-tag-filter={tag} aria-pressed="false">{tag}</button>
      ))}
    </div>

    <p class="archive-count" data-post-count>{posts.length} posts</p>
  </section>

  <section class="shell archive-list" data-post-list>
    {posts.map((post) => (
      <a
        class="archive-item"
        href={`${base}posts/${post.id}/`}
        data-post-item
        data-tags={post.data.tags.join(',')}
        data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`.toLowerCase()}
      >
        <div class="archive-item__media" aria-hidden={!post.data.coverImage}>
          {post.data.coverImage ? (
            <img src={resolveAssetPath(post.data.coverImage, base)} alt="" loading="lazy" decoding="async" />
          ) : (
            <span>{site.blogName}</span>
          )}
        </div>
        <div class="archive-item__content">
          <p class="archive-item__meta"><time>{formatDate(post.data.date)}</time> · {getReadingTime(post.body)} min read</p>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <span>{post.data.tags.join(' · ')}</span>
        </div>
      </a>
    ))}
    <p class="archive-empty" data-post-empty hidden>No posts match the current search.</p>
  </section>

  <script>
    const searchInput = document.querySelector<HTMLInputElement>('[data-post-search]');
    const postItems = Array.from(document.querySelectorAll<HTMLElement>('[data-post-item]'));
    const tagButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]'));
    const count = document.querySelector<HTMLElement>('[data-post-count]');
    const empty = document.querySelector<HTMLElement>('[data-post-empty]');
    const selectedTags = new Set<string>();
    let frame = 0;

    const posts = postItems.map((element) => ({
      element,
      search: element.getAttribute('data-search') || '',
      tags: new Set<string>((element.getAttribute('data-tags') || '').split(',').filter(Boolean)),
    }));

    type PostFilterItem = (typeof posts)[number];

    function postMatches(post: PostFilterItem, query: string, tags: Set<string> = selectedTags) {
      if (query && !post.search.includes(query)) return false;
      for (const tag of tags) {
        if (!post.tags.has(tag)) return false;
      }
      return true;
    }

    function scheduleFilter() {
      cancelAnimationFrame(frame);
      frame = requestAnimationFrame(applyFilters);
    }

    function applyFilters() {
      const query = (searchInput?.value || '').trim().toLowerCase();
      let visible = 0;

      for (const post of posts) {
        const matches = postMatches(post, query);
        post.element.hidden = !matches;
        post.element.classList.toggle('is-hidden', !matches);
        post.element.setAttribute('aria-hidden', String(!matches));
        post.element.style.display = matches ? '' : 'none';
        if (matches) visible++;
      }

      for (const button of tagButtons) {
        const tag = button.getAttribute('data-tag-filter');
        if (!tag) continue;

        const tagsWithoutCurrent = new Set(selectedTags);
        tagsWithoutCurrent.delete(tag);
        const hasMatches = posts.some((post) => post.tags.has(tag) && postMatches(post, query, tagsWithoutCurrent));
        const isSelected = selectedTags.has(tag);

        const hideButton = !isSelected && !hasMatches;
        button.hidden = hideButton;
        button.classList.toggle('is-hidden', hideButton);
        button.setAttribute('aria-hidden', String(hideButton));
        button.style.display = hideButton ? 'none' : '';
        button.setAttribute('aria-pressed', String(isSelected));
        button.classList.toggle('is-selected', isSelected);
      }

      if (count) count.textContent = `${visible} ${visible === 1 ? 'post' : 'posts'}`;
      if (empty) empty.hidden = visible !== 0;
    }

    searchInput?.addEventListener('input', scheduleFilter, { passive: true });
    for (const button of tagButtons) {
      button.addEventListener('click', () => {
        const tag = button.getAttribute('data-tag-filter');
        if (!tag) return;
        if (selectedTags.has(tag)) selectedTags.delete(tag);
        else selectedTags.add(tag);
        scheduleFilter();
      });
    }

    applyFilters();
  </script>
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import { formatDate } from '../lib/utils';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="NaeesSecurity — notes archive" description="NaeesSecurity: essays, security notes, and technical writing by Naees." pathname="/posts/">
  <section class="page-hero shell">
    <p class="eyebrow">NaeesSecurity</p>
    <h1>The blog layer: essays, notes, and research fragments.</h1>
    <p class="lede">A quieter archive for thoughts that need more room than a console line: security, technology, reading, systems, and field notes in progress.</p>
  </section>

  <section class="shell archive-list">
    {posts.map((post) => (
      <a class="archive-item" href={`${base}posts/${post.id}/`}>
        <time>{formatDate(post.data.date)}</time>
        <div>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <span>{post.data.tags.join(' · ')}</span>
        </div>
      </a>
    ))}
  </section>
</Layout>

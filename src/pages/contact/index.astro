---
import Layout from '../../components/Layout.astro';
import { site } from '../../data/site';
const base = import.meta.env.BASE_URL;
---

<Layout title="Contact — Naees" description="PGP fingerprint, public key, Signal, and contact details for Naees." pathname="/contact/">
  <section class="page-hero shell">
    <p class="eyebrow">contact / keys</p>
    <h1>Verify before you trust the channel.</h1>
    <p class="lede">Use the public key for encrypted mail. If the context is sensitive, prefer a verified secure channel and check the fingerprint below.</p>
  </section>

  <section class="shell key-panel">
    <p class="eyebrow">PGP fingerprint</p>
    <code>{site.pgpFingerprint}</code>
    <div class="actions">
      <a class="button button--primary" href={`${base}keys/publickey.naees.asc`} download>Download public key</a>
      <a class="button" href={site.signal} target="_blank" rel="noopener noreferrer">Message on Signal</a>
    </div>
  </section>

  <section class="shell contact-form-section" aria-labelledby="contact-title">
    <div>
      <p class="eyebrow">contact</p>
      <h2 id="contact-title">Send an email</h2>
      <p>Share a subject and a short description. The form opens a pre-filled email draft addressed to Naees; it does not send anything until you review and send it from your mail client.</p>
    </div>
    <form class="contact-form" data-mailto-form>
      <label>
        <span>Subject</span>
        <input name="subject" type="text" placeholder="Security collaboration / disclosure / question" required />
      </label>
      <label>
        <span>Description</span>
        <textarea name="body" rows="8" placeholder="Hi Naees,&#10;&#10;I’m reaching out about...&#10;&#10;Context:&#10;Scope:&#10;Timeline:&#10;Preferred reply channel:" required></textarea>
      </label>
      <button class="button button--primary" type="submit">Open email draft</button>
    </form>
  </section>

  <section class="shell contact-grid">
    <a href={`mailto:${site.email}`}><span>Email</span> {site.email}</a>
    <a href={site.github} target="_blank" rel="noopener noreferrer"><span>GitHub</span> github.com/Naees</a>
    <a href={site.x} target="_blank" rel="noopener noreferrer"><span>X</span> x.com/NaeesSecurity</a>
  </section>

  <script define:vars={{ email: site.email }}>
    const form = document.querySelector('[data-mailto-form]');
    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const subject = String(data.get('subject') || 'Contact from NaeesSecurity');
      const body = String(data.get('body') || '');
      window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</Layout>

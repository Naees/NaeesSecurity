---
import Layout from '../../components/Layout.astro';
import { issueUrl, site } from '../../data/site';

const base = import.meta.env.BASE_URL;
const publicKeyUrl = `${base}keys/publickey.naees.asc`;

const contactIcons = {
  email: ['M4.5 7.5h15v10h-15z', 'm5.5 8.5 6.5 5 6.5-5'],
  signal: ['M8 16.5 5 19v-4.5a7 7 0 1 1 3 2z', 'M9 10.5h6M9 13h4'],
  key: ['M4.75 12a3.25 3.25 0 1 0 6.5 0 3.25 3.25 0 0 0-6.5 0', 'M11.25 12H20M17 12v3M14.5 12v2'],
  github: ['M9 18.5c-3 .8-3-1.5-4.2-2', 'M15 21v-3.4c0-.9-.3-1.5-.8-1.9 2.6-.3 5.3-1.3 5.3-5.8 0-1.3-.5-2.4-1.2-3.3.1-.3.5-1.6-.1-3.2 0 0-1-.3-3.4 1.2a11.5 11.5 0 0 0-6.2 0C6.2 3.1 5.2 3.4 5.2 3.4c-.6 1.6-.2 2.9-.1 3.2A4.7 4.7 0 0 0 4 9.9c0 4.5 2.7 5.5 5.3 5.8-.4.4-.7 1-.8 1.8V21'],
  issue: ['M12 4.5 20 19H4z', 'M12 9v4.2', 'M12 16.5h.01'],
} as const;

type ContactIcon = keyof typeof contactIcons;

type BaseContactMethod = {
  icon: ContactIcon;
  title: string;
  value: string;
};

type StandardContactMethod = BaseContactMethod & {
  action: string;
  href?: string;
  copy?: string;
  pgp?: false;
};

type PgpContactMethod = BaseContactMethod & {
  pgp: true;
  href: string;
  copy: string;
};

type ContactMethod = StandardContactMethod | PgpContactMethod;

const contactMethods: ContactMethod[] = [
  {
    icon: 'email',
    title: 'Email',
    value: site.email,
    action: 'Copy email',
    copy: site.email,
  },
  {
    icon: 'signal',
    title: 'Signal',
    value: site.signalHandle,
    action: 'Open Signal',
    href: site.signal,
  },
  {
    icon: 'key',
    title: 'PGP key',
    value: site.pgpFingerprint,
    href: publicKeyUrl,
    copy: site.pgpFingerprint,
    pgp: true,
  },
  {
    icon: 'github',
    title: 'GitHub',
    value: 'Naees',
    action: 'Open GitHub',
    href: site.github,
  },
  {
    icon: 'issue',
    title: 'Site issue',
    value: 'GitHub Issues',
    action: 'Open issue',
    href: issueUrl,
  },
];

const verificationSteps = [
  ['01', 'Match', 'Compare the full PGP fingerprint exactly before trusting a key or encrypted message.'],
  ['02', 'Cross-check', 'Confirm identity through a second known channel before sharing sensitive context.'],
  ['03', 'Encrypt', 'Use PGP email or Signal for vulnerability details, private artifacts, or engagement material.'],
  ['04', 'Separate', 'Keep public site issues limited to non-sensitive website problems.'],
];

const isExternalHref = (href?: string) => href?.startsWith('http');
---

<Layout title="Contact — NaeesSecurity" description="Secure contact, PGP fingerprint, public key, Signal, and verification details for NaeesSecurity." pathname="/contact/">
  <section class="ns-shell ns-page-header ns-page-header-single ns-contact-hero">
    <div>
      <p class="ns-kicker">contact & verification</p>
      <h1 class="ns-page-title">Contact</h1>
      <p class="ns-subtitle">Verify before you trust.</p>
      <p class="ns-lede">Use a verified channel before sending sensitive material. For vulnerability details or engagement artifacts, prefer encrypted email or Signal after confirming identity.</p>
      <div class="ns-actions">
        <a class="ns-button ns-button-primary" href={`mailto:${site.email}`}>Email</a>
        <a class="ns-button" href="#pgp-fingerprint">Verify fingerprint</a>
      </div>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell">
      <div class="ns-table-wrap ns-contact-methods">
        <div class="ns-table-header"><h2>Contact overview</h2><span class="ns-meta">Channels · verification paths</span></div>
        <div class="ns-contact-method-grid">
          {contactMethods.map((method) => (
            <article id={method.pgp ? 'pgp-fingerprint' : undefined} class:list={['ns-contact-method-card', method.pgp && 'ns-contact-method-card-pgp']}>
              <div class="ns-contact-method-card__top">
                <span class="ns-contact-method-art" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    {contactIcons[method.icon].map((path) => <path d={path} />)}
                  </svg>
                </span>
                <div>
                  <h3>{method.title}</h3>
                  {!method.pgp && <code>{method.value}</code>}
                </div>
              </div>
              {method.pgp ? (
                <>
                  <div class="ns-pgp-fingerprint-block">
                    <span>Full fingerprint</span>
                    <code>{method.value}</code>
                  </div>
                  <div class="ns-contact-method-card__stacked-actions">
                    <button class="ns-button" type="button" data-copy={method.copy}>Copy fingerprint</button>
                    <a class="ns-button ns-button-primary" href={method.href} download>Download public key</a>
                  </div>
                </>
              ) : (
                <div class="ns-contact-method-card__action">
                  {method.copy ? (
                    <button class="ns-button" type="button" data-copy={method.copy}>{method.action}</button>
                  ) : (
                    <a class="ns-button" href={method.href} target={isExternalHref(method.href) ? '_blank' : undefined} rel={isExternalHref(method.href) ? 'noopener noreferrer' : undefined}>{method.action}</a>
                  )}
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell ns-contact-verification-band">
      <div>
        <p class="ns-kicker">disclaimer</p>
        <h2>Do not send sensitive details until the channel is confirmed.</h2>
        <p>Include only the minimum context needed to start. Once identity and scope are confirmed, move vulnerability details, artifacts, and reproduction notes to encrypted email or Signal.</p>
        <p class="ns-contact-liability-note">Our team is not liable for confidential, personal, regulated, or sensitive data submitted without proper authorization, redaction, or encryption. You are responsible for using an appropriate secure channel and ensuring you have consent to disclose any material shared.</p>
      </div>
      <div class="ns-contact-verification-steps">
        {verificationSteps.map(([number, title, text]) => (
          <article>
            <b>{number}</b>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('[data-copy]').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.getAttribute('data-copy') || '';
        try {
          await navigator.clipboard.writeText(value);
          const oldText = button.textContent;
          button.textContent = 'Copied';
          window.setTimeout(() => { button.textContent = oldText; }, 1400);
        } catch {
          window.prompt('Copy value', value);
        }
      });
    });
  </script>
</Layout>

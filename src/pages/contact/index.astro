---
import Layout from '../../components/Layout.astro';
import { issueUrl, site } from '../../data/site';
const base = import.meta.env.BASE_URL;

const contactMethods = [
  {
    number: '01',
    title: 'Email',
    value: site.email,
    note: 'Best for scoped work, follow-up, and non-urgent coordination.',
    action: 'Copy email',
    copy: site.email,
  },
  {
    number: '02',
    title: 'Signal',
    value: site.signalHandle,
    note: 'Use for sensitive coordination after identity has been verified.',
    action: 'Open Signal',
    href: site.signal,
  },
  {
    number: '03',
    title: 'PGP key',
    value: '0x48CCB80F',
    note: 'Use for encrypted email and fingerprint verification.',
    action: 'Download key',
    href: `${base}keys/publickey.naees.asc`,
    download: true,
  },
  {
    number: '04',
    title: 'Site issue',
    value: 'GitHub Issues',
    note: 'Only for typos, broken links, or public site bugs. Do not post sensitive details.',
    action: 'Open issue',
    href: issueUrl,
  },
];

const verificationSteps = [
  ['01', 'Match', 'Compare the full PGP fingerprint exactly before trusting a key or encrypted message.'],
  ['02', 'Cross-check', 'Confirm identity through a second known channel before sharing sensitive context.'],
  ['03', 'Encrypt', 'Use PGP email or Signal for vulnerability details, private artifacts, or engagement material.'],
  ['04', 'Separate', 'Keep public site issues limited to non-sensitive website problems.'],
];

const pgpBlocks = site.pgpFingerprint.split(' ');
---

<Layout title="Contact — NaeesSecurity" description="Secure contact, PGP fingerprint, public key, Signal, and verification details for NaeesSecurity." pathname="/contact/">
  <section class="ns-shell ns-page-header ns-contact-hero">
    <div>
      <p class="ns-kicker">contact & verification</p>
      <h1 class="ns-page-title">Contact</h1>
      <p class="ns-subtitle">Verify before you trust.</p>
      <p class="ns-lede">Use a verified channel before sending sensitive material. For vulnerability details or engagement artifacts, prefer encrypted email or Signal after confirming identity.</p>
      <div class="ns-actions">
        <a class="ns-button ns-button-primary" href={`mailto:${site.email}`}>Email securely</a>
        <a class="ns-button" href="#pgp-fingerprint">Verify fingerprint</a>
      </div>
    </div>
    <aside class="ns-contact-fingerprint-terminal" aria-label="PGP verification summary">
      <div class="ns-attack-terminal__chrome">
        <span class="ns-attack-terminal__controls" aria-hidden="true">
          <span class="ns-terminal-dot ns-terminal-dot-close"></span>
          <span class="ns-terminal-dot ns-terminal-dot-minimize"></span>
          <span class="ns-terminal-dot ns-terminal-dot-fullscreen"></span>
        </span>
        <span class="ns-attack-terminal__title">naees@TargetBox: ~/verify</span>
        <span class="ns-attack-terminal__mode">identity check</span>
      </div>
      <div class="ns-contact-fingerprint-terminal__body">
        <p><span class="ns-terminal-prompt">naees@TargetBox:~$</span> gpg --fingerprint naees</p>
        <div class="ns-fingerprint-grid" id="pgp-fingerprint" aria-label="PGP fingerprint">
          {pgpBlocks.map((block) => <span>{block}</span>)}
        </div>
        <dl>
          <div class="ns-stat-row"><dt>Key ID</dt><dd>0x48CCB80F</dd></div>
          <div class="ns-stat-row"><dt>Channel</dt><dd>{site.email}</dd></div>
          <div class="ns-stat-row"><dt>Status</dt><dd><span class="ns-status ns-status-active">Verified</span></dd></div>
        </dl>
      </div>
    </aside>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell">
      <div class="ns-table-wrap ns-contact-methods">
        <div class="ns-table-header"><h2>Secure contact</h2><span class="ns-meta">Channels · handling guidance</span></div>
        <div class="ns-contact-method-grid">
          {contactMethods.map((method) => (
            <article class="ns-contact-method-card">
              <div class="ns-contact-method-card__top">
                <span class="ns-engagement-type-icon" aria-hidden="true">{method.number}</span>
                <div>
                  <h3>{method.title}</h3>
                  <code>{method.value}</code>
                </div>
              </div>
              <p>{method.note}</p>
              {method.copy ? (
                <button class="ns-button" type="button" data-copy={method.copy}>{method.action}</button>
              ) : (
                <a class="ns-button" href={method.href} target={method.href?.startsWith('http') ? '_blank' : undefined} rel={method.href?.startsWith('http') ? 'noopener noreferrer' : undefined} download={method.download ? true : undefined}>{method.action}</a>
              )}
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell ns-contact-verification-band">
      <div>
        <p class="ns-kicker">verification first</p>
        <h2>Do not send sensitive details until the channel is confirmed.</h2>
        <p>Include only the minimum context needed to start. Once identity and scope are confirmed, move vulnerability details, artifacts, and reproduction notes to encrypted email or Signal.</p>
      </div>
      <div class="ns-contact-verification-steps">
        {verificationSteps.map(([number, title, text]) => (
          <article>
            <b>{number}</b>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell ns-contact-key-panel">
      <div>
        <p class="ns-kicker">public key</p>
        <h2>PGP fingerprint</h2>
        <p class="ns-fingerprint">{site.pgpFingerprint}</p>
      </div>
      <div class="ns-actions">
        <button class="ns-button" type="button" data-copy={site.pgpFingerprint}>Copy fingerprint</button>
        <a class="ns-button ns-button-primary" href={`${base}keys/publickey.naees.asc`} download>Download public key</a>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('[data-copy]').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.getAttribute('data-copy') || '';
        try {
          await navigator.clipboard.writeText(value);
          const oldText = button.textContent;
          button.textContent = 'Copied';
          window.setTimeout(() => { button.textContent = oldText; }, 1400);
        } catch {
          window.prompt('Copy value', value);
        }
      });
    });
  </script>
</Layout>

---
import Layout from '../../components/Layout.astro';
import { issueUrl, site } from '../../data/site';
const base = import.meta.env.BASE_URL;
---

<Layout title="Contact — NaeesSecurity" description="Secure contact, PGP fingerprint, public key, Signal, and verification details for NaeesSecurity." pathname="/contact/">
  <section class="ns-section ns-section-top">
    <div class="ns-shell ns-grid ns-grid-sidebar-contact ns-align-start">
      <div>
        <header style="padding-block: 1rem 1rem; border-bottom: var(--hairline);">
          <p class="ns-kicker">contact & verification</p>
          <h1 class="ns-page-title">Contact</h1>
          <p class="ns-subtitle">Verify before you trust.</p>
          <p class="ns-lede">I use a minimal set of communication channels. Always verify identity before sharing sensitive information. When in doubt, use PGP.</p>
        </header>

        <section class="ns-contact-list" aria-labelledby="secure-contact-title" style="margin-top: 1rem;">
          <div class="ns-table-header"><h2 id="secure-contact-title">Secure contact</h2></div>
          <div class="ns-contact-row">
            <span class="ns-meta">01</span>
            <span class="ns-contact-icon" aria-hidden="true">✉</span>
            <div><h3>Email</h3><code>{site.email}</code></div>
            <button class="ns-button" type="button" data-copy={site.email}>Copy email</button>
          </div>
          <div class="ns-contact-row">
            <span class="ns-meta">02</span>
            <span class="ns-contact-icon" aria-hidden="true">☏</span>
            <div><h3>Signal</h3><code>{site.signalHandle}</code></div>
            <a class="ns-button" href={site.signal} target="_blank" rel="noopener noreferrer">Open Signal</a>
          </div>
          <div class="ns-contact-row">
            <span class="ns-meta">03</span>
            <span class="ns-contact-icon" aria-hidden="true">⚿</span>
            <div>
              <h3>PGP public key</h3>
              <p>Use to verify email and sensitive messages.</p>
              <p class="ns-fingerprint">{site.pgpFingerprint}</p>
              <div class="ns-actions" style="margin-top: 1rem;">
                <button class="ns-button" type="button" data-copy={site.pgpFingerprint}>Copy fingerprint</button>
                <a class="ns-button" href={`${base}keys/publickey.naees.asc`} download>Download public key</a>
              </div>
            </div>
          </div>
          <div class="ns-contact-row">
            <span class="ns-meta">04</span>
            <span class="ns-contact-icon" aria-hidden="true">⌬</span>
            <div><h3>Report a site issue</h3><p>Use GitHub Issues for broken links, typos, or site bugs. Do not post sensitive vulnerability details publicly.</p></div>
            <a class="ns-button" href={issueUrl} target="_blank" rel="noopener noreferrer">Open site issue</a>
          </div>
        </section>

        <div class="ns-alert" style="margin-top: 1.5rem;">
          <span aria-hidden="true">⚠</span>
          <p>Always verify before you trust. Confirm fingerprints via multiple trusted channels. For sensitive reports, use encrypted email or Signal rather than a public issue.</p>
          <a class="ns-link-arrow" href={`mailto:${site.email}`}>Email with PGP</a>
        </div>
      </div>

      <aside class="ns-sidebar" aria-label="Contact verification sidebar">
        <section class="ns-panel ns-panel-pad" aria-labelledby="identity-fingerprint-title">
          <h2 id="identity-fingerprint-title">Identity fingerprint <span class="ns-status ns-status-active" style="float: right;">Verified</span></h2>
          <div class="ns-fingerprint-card">
            <div class="ns-fingerprint-art" aria-hidden="true">⌁</div>
            <dl>
              <div class="ns-stat-row"><dt>operator</dt><dd>Naees</dd></div>
              <div class="ns-stat-row"><dt>handle</dt><dd>naees</dd></div>
              <div class="ns-stat-row"><dt>key id</dt><dd>0x48CCB80F</dd></div>
              <div class="ns-stat-row"><dt>algo</dt><dd>ed25519</dd></div>
              <div class="ns-stat-row"><dt>expires</dt><dd>never</dd></div>
            </dl>
          </div>
          <p class="ns-fingerprint" style="margin-top: 1rem;">{site.pgpFingerprint}</p>
          <button class="ns-button" type="button" data-copy={site.pgpFingerprint}>Copy fingerprint</button>
        </section>
        <section class="ns-panel ns-panel-pad">
          <h2>Verification checklist</h2>
          <ul class="ns-mini-list">
            <li><span>✓</span><span>Confirm fingerprint matches exactly</span></li>
            <li><span>✓</span><span>Verify via at least two trusted channels</span></li>
            <li><span>✓</span><span>Check key ID when importing PGP key</span></li>
            <li><span>✓</span><span>Use Signal or encrypted email for sensitive conversations</span></li>
            <li><span>✓</span><span>Use GitHub Issues only for non-sensitive site problems</span></li>
          </ul>
        </section>
        <section class="ns-panel ns-panel-pad">
          <h2>Operator availability</h2>
          <dl>
            <div class="ns-stat-row"><dt>Time zone</dt><dd>SGT (UTC+08:00)</dd></div>
            <div class="ns-stat-row"><dt>Typical response</dt><dd>24–72 hours</dd></div>
            <div class="ns-stat-row"><dt>Best effort</dt><dd>Mon – Fri business hours</dd></div>
            <div class="ns-stat-row"><dt>Low activity</dt><dd>Weekends / public holidays</dd></div>
          </dl>
          <p class="ns-meta">Emergencies involving active exploitation or public harm may be prioritized.</p>
        </section>
      </aside>
    </div>
  </section>

  <script>
    document.querySelectorAll('[data-copy]').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.getAttribute('data-copy') || '';
        try {
          await navigator.clipboard.writeText(value);
          const oldText = button.textContent;
          button.textContent = 'Copied';
          window.setTimeout(() => { button.textContent = oldText; }, 1400);
        } catch {
          window.prompt('Copy fingerprint', value);
        }
      });
    });
  </script>
</Layout>

---
import Layout from '../components/Layout.astro'
import DarkModeToggle from '../components/DarkModeToggle.astro'
---

<Layout
  title="404 — Not Found"
  description="The page you are looking for does not exist."
  pathname="/404"
>
  <div slot="darkModeToggle"><DarkModeToggle /></div>

  <div class="container" style="display: flex; align-items: center; justify-content: center; min-height: 60vh; position: relative;">
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); opacity: 0.03; pointer-events: none;">
      <img src="/haku.svg" alt="" style="width: 400px; height: auto;" />
    </div>
    <div style="text-align: center; max-width: 480px; position: relative; z-index: 1;">
      <div style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1rem;">
        <span style="color: var(--red);">$</span> cat /dev/null
      </div>
      <h1 style="font-size: 6rem; margin: 0; color: var(--red); font-family: var(--font-mono); letter-spacing: -0.05em;">404</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; margin-top: 1rem; margin-bottom: 2rem;">
        The page you are looking for does not exist.
      </p>
      <a
        href="/"
        style="display: inline-block; padding: 0.75rem 1.5rem; font-family: var(--font-mono); font-size: 0.875rem; background-color: var(--accent); color: var(--bg); text-decoration: none; border-radius: 6px; font-weight: 600; transition: opacity 0.15s ease;"
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'"
      >
        &larr; Go home
      </a>
    </div>
  </div>
</Layout>

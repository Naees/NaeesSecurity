---
import Layout from '../components/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="404 — Naees" description="Page not found." pathname="/404/">
  <section class="page-hero shell">
    <p class="eyebrow">404</p>
    <h1>This path does not resolve.</h1>
    <p class="lede">The file may have moved, never existed, or failed quietly in the archive.</p>
    <a class="button button--primary" href={base}>Return home</a>
  </section>
</Layout>

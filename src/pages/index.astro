---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import Console from '../components/Console.astro';
import { site } from '../data/site';
import { formatDate } from '../lib/utils';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title={`${site.name} — security research and ${site.blogName}`} description={site.description} pathname="/" pageClass="home-page">
  <section class="hero shell">
    <div class="hero__copy">
      <p class="eyebrow">security research · writing archive · field notes</p>
      <h1>I study how systems fail at the edges.</h1>
      <p class="lede">I’m Naees. This site collects my security research practice, technical writing, and notes on web systems, identity, cloud exposure, and the strange failure modes that hide between assumptions.</p>
      <div class="actions">
        <a class="button button--primary" href={`${base}research/`}>Open case files</a>
        <a class="button" href={`${base}keys/`}>Contact securely</a>
      </div>
    </div>
    <Console />
  </section>

  <section class="strip" aria-label="Site sections">
    <a href={`${base}research/`}><span>01</span> Research placeholders and future writeups</a>
    <a href={`${base}posts/`}><span>02</span> NaeesSecurity essays and notes</a>
    <a href={`${base}about/`}><span>03</span> About Naees and Haku</a>
  </section>

  <section class="shell split-section">
    <div>
      <p class="eyebrow">current posture</p>
      <h2>Balanced between personal archive and professional signal.</h2>
    </div>
    <div class="prose-card">
      <p>I’m open to collaboration and security-focused engagement. The public archive is intentionally early: a place for clean notes, reproducible thinking, and future case files rather than inflated claims.</p>
      <p>NaeesSecurity is the blog and research layer of the site — slower writing, reading notes, technical essays, and research fragments worth keeping.</p>
    </div>
  </section>

  <section class="shell">
    <div class="section-heading">
      <p class="eyebrow">latest from NaeesSecurity</p>
      <a href={`${base}posts/`}>View archive →</a>
    </div>
    <div class="card-grid">
      {posts.map((post) => (
        <a class="case-card" href={`${base}posts/${post.id}/`}>
          <span>{formatDate(post.data.date)}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>

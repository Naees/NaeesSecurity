---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import { featuredCases } from '../data/research';
import { site } from '../data/site';
import { formatDate } from '../lib/utils';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const cases = featuredCases;

const engagementFlow = [
  {
    label: 'Scope',
    title: 'Confirm the boundaries',
    text: 'Define assets, objectives, test window, rules of engagement, and emergency contact paths before work begins.',
  },
  {
    label: 'Map',
    title: 'Build the attack-surface view',
    text: 'Identify entry points, roles, trust boundaries, exposed services, and high-risk workflows inside the agreed scope.',
  },
  {
    label: 'Test',
    title: 'Validate safely',
    text: 'Reproduce weaknesses with non-destructive checks, capture evidence, and avoid actions outside authorization.',
  },
  {
    label: 'Report',
    title: 'Write what matters',
    text: 'Deliver concise executive and technical findings with severity, impact, evidence, and remediation guidance.',
  },
  {
    label: 'Retest',
    title: 'Close the loop',
    text: 'Review fixes, update finding status, and provide validation notes that show what changed.',
  },
];
---

<Layout title="NaeesSecurity — security research by Naees" description={site.description} pathname="/" pageClass="home-page">
  <section class="ns-shell ns-hero">
    <div>
      <p class="ns-kicker">security research · writing archive · field notes</p>
      <h1 class="ns-title">I study how systems fail at the edges.</h1>
      <p class="ns-lede">I’m Naees. This site collects my security research practice, technical writing, and notes on web systems, identity, cloud exposure, and the strange failure modes that hide between assumptions.</p>
      <div class="ns-actions">
        <a class="ns-button ns-button-primary" href={`${base}research/`}>Browse case notes →</a>
        <a class="ns-button" href={`${base}contact/`}>Contact securely</a>
      </div>
      <dl class="ns-focus-row" aria-label="Research focus">
        <dt>Focus</dt>
        <dd>{site.focus.join(' · ')}</dd>
      </dl>
    </div>

    <aside class="ns-console" aria-label="Operator status">
      <div class="ns-console-header">
        <span>Operator status</span>
        <span class="ns-console-status"><span class="ns-status-dot"></span> operator.naees</span>
      </div>
      <dl class="ns-console-body">
        <div class="ns-ledger-row"><dt>status</dt><dd>open to collaboration</dd></div>
        <div class="ns-ledger-row"><dt>role</dt><dd>security researcher</dd></div>
        <div class="ns-ledger-row"><dt>focus</dt><dd>{site.focus.join(' · ')}</dd></div>
        <div class="ns-ledger-row"><dt>location</dt><dd>{site.location}</dd></div>
        <div class="ns-ledger-row"><dt>latest</dt><dd>{cases[0].id} · {cases[0].surface.toLowerCase()}</dd></div>
        <div class="ns-ledger-row"><dt>verify</dt><dd>PGP fingerprint and secure channels are on the contact page.</dd></div>
        <dd class="ns-command">$ ./read-latest --signal-noise low{`\n>`} connecting to archive index... ok{`\n>`} loading latest entries... ok{`\n>`} {cases.length} featured notes, 1 active case</dd>
      </dl>
      <div class="ns-console-footer" aria-label="Console telemetry">
        <span>archive live</span><span>sync <b>ok</b></span><span>{cases.length} featured</span><span>noise <b>low</b></span>
      </div>
    </aside>
  </section>

  <section class="ns-section-tight" aria-labelledby="engagement-loop-title">
    <div class="ns-shell">
      <div class="ns-table-header" style="padding-inline: 0; border: 0; box-shadow: none; background: transparent;">
        <h2 id="engagement-loop-title">Engagement loop</h2>
        <span class="ns-meta">How scoped work moves from permission to validation</span>
      </div>
      <div class="ns-engagement-topic">
        <div class="ns-process ns-process-linear ns-engagement-loop-process">
          {engagementFlow.map((step) => (
            <article class="ns-process-step">
              <span class="ns-process-label">{step.label}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
        <div class="ns-engagement-loop-cta">
          <div>
            <p class="ns-kicker">engagements</p>
            <h3>Need the full scope, access models, and deliverables?</h3>
            <p>Compare black-box, grey-box, and white-box testing models, review the expected inputs and outputs, then start with a scoped request.</p>
          </div>
          <div class="ns-engagement-loop-cta__actions">
            <a class="ns-button ns-button-primary" href={`${base}engagements/`}>View engagement details</a>
            <a class="ns-button" href={`${base}contact/?subject=Security%20engagement%20request`}>Request scope discussion</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell ns-table-wrap">
      <div class="ns-table-header">
        <h2>Case note index</h2>
        <a class="ns-link-arrow" href={`${base}research/`}>View all case notes</a>
      </div>
      <table class="ns-table">
        <thead>
          <tr><th>ID</th><th>Case ID</th><th>Subject</th><th>Tags</th><th>Updated</th><th>Status</th></tr>
        </thead>
        <tbody>
          {cases.map((item, index) => (
            <tr>
              <td>{String(index + 1).padStart(2, '0')}</td>
              <td><a class="ns-case-id" href={`${base}research/${item.slug}/`}>{item.id}</a></td>
              <td>{item.subject}</td>
              <td><ul class="ns-chip-list">{item.tags.map((tag) => <li class="ns-chip">{tag}</li>)}</ul></td>
              <td class="ns-nowrap">{item.updated}</td>
              <td><span class:list={['ns-status', `ns-status-${item.status.toLowerCase()}`]}>{item.status}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell">
      <div class="ns-table-header" style="padding-inline: 0; border: 0; box-shadow: none; background: transparent;">
        <h2>Latest from NaeesWrites</h2>
        <a class="ns-link-arrow" href={`${base}posts/`}>View all writing</a>
      </div>
      <div class="ns-grid ns-grid-3">
        {posts.map((post) => (
          <a class="ns-card" href={`${base}posts/${post.id}/`}>
            <div class="ns-card-header">
              <span class="ns-meta">{formatDate(post.data.date)} · field note</span>
              <span aria-hidden="true">↗</span>
            </div>
            <h3 class="ns-card-title">{post.data.title}</h3>
            <p>{post.data.description}</p>
            <ul class="ns-chip-list">{post.data.tags.slice(0, 3).map((tag) => <li class="ns-chip">{tag}</li>)}</ul>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

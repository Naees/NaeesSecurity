---
import Layout from '../components/Layout.astro';

const base = import.meta.env.BASE_URL;

const workingNotes = ['Verify before publishing', 'Keep public notes sanitized', 'Prefer useful evidence over loud claims'];

const deskMembers = [
  {
    name: 'Sean Er',
    role: 'Founder · security researcher · writer',
    image: `${base}assets/goobers.webp`,
    alt: 'Sean Er and Haku',
    text: 'Security researcher focused on web, identity, cloud, and practical exploitation. I build, test, document, and reduce findings to useful lessons.',
    links: [
      { label: 'github', href: 'https://github.com/Naees' },
      { label: 'x', href: 'https://x.com/NaeesSecurity' },
      { label: 'signal', href: 'https://signal.me/#eu/1Fkdlvu4vmAqdT-5QwGdGFH1b4uOrLlpyMlK8Fyr5aw_eu6XMJ1PEYOH18jG1nMY' },
    ],
  },
  {
    name: 'Haku',
    role: 'Co-author',
    image: `${base}assets/haku.webp`,
    alt: 'Haku',
    text: 'A suspiciously fluffy security researcher operating under deep cover as a dog. Haku specializes in sniffing packets, escalating privileges to the snack drawer, and approving drafts only after a proper walk.',
    links: [],
  },
];
---

<Layout title="About — NaeesSecurity" description="About Sean Er, Haku, and the NaeesSecurity research desk." pathname="/about/">
  <section class="ns-section ns-section-top">
    <div class="ns-shell">
        <header class="ns-page-header ns-page-header-inline ns-page-header-single">
          <div>
            <p class="ns-kicker">about</p>
            <h1 class="ns-page-title ns-page-title-statement">A small security research desk for verified, useful findings.</h1>
            <p class="ns-lede">I’m Sean Er. I study how systems fail at trust boundaries across web, identity, and cloud. This site is the public layer: sanitized case notes, field writing, contact details, and scoped engagement information.</p>
          </div>
        </header>

        <section class="ns-section-tight ns-about-section-stack">
          <div class="ns-about-intro-grid">
            <article class="ns-panel ns-panel-pad ns-about-intro-card">
              <p class="ns-kicker">about us</p>
              <h2>Independent research, clear notes, no theatre.</h2>
              <p>NaeesSecurity is an independent security research desk run by Sean Er, with Haku as unofficial co-author and morale officer. The desk focuses on careful research, clear writing, and scoped security work without turning findings into performance.</p>
            </article>
            <article class="ns-panel ns-panel-pad ns-about-principles-card">
              <p class="ns-kicker">how we work</p>
              <ul class="ns-mini-list">
                {workingNotes.map((note) => <li><span>→</span><span>{note}</span></li>)}
              </ul>
            </article>
          </div>
        </section>

        <section class="ns-section-tight ns-about-section-stack">
          <div class="ns-table-header ns-about-section-heading"><h2>Meet the team</h2><span class="ns-meta">Small team · clear roles</span></div>
          <div class="ns-desk-grid">
            {deskMembers.map((member) => (
              <article class="ns-card ns-desk-card">
                <img src={member.image} alt={member.alt} loading="lazy" decoding="async" />
                <div>
                  <h3>{member.name}</h3>
                  <p class="ns-meta">{member.role}</p>
                  <p>{member.text}</p>
                  {member.links.length > 0 && (
                    <ul class="ns-chip-list">
                      {member.links.map((link) => (
                        <li><a class="ns-chip" href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a></li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="ns-section-tight ns-about-section-stack" aria-labelledby="about-contact-title">
          <div class="ns-secure-contact-band ns-about-contact-band">
            <div>
              <p class="ns-kicker">contact</p>
              <h2 id="about-contact-title">Need to verify identity, send a report, or discuss scoped work?</h2>
              <p>The contact page keeps the practical details in one place: email, Signal, GitHub, PGP fingerprint, public key download, and reporting guidance.</p>
            </div>
            <div class="ns-secure-contact-band__action">
              <a class="ns-button ns-button-primary" href={`${base}contact/`}>Open contact page</a>
            </div>
          </div>
        </section>
    </div>
  </section>
</Layout>

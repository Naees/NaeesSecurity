---
import Layout from '../components/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Meet the team — NaeesSecurity" description="Meet the small team behind NaeesSecurity: Naees and Haku." pathname="/about/">
  <section class="page-hero shell page-hero--with-mark">
    <p class="eyebrow">meet the team</p>
    <h1>A small research desk with one operator and one very strict morale officer.</h1>
    <p class="lede">NaeesSecurity is maintained by Naees as a public home for security notes, technical writing, and useful edge cases. Haku handles operational resilience, walk enforcement, and keyboard-adjacent supervision.</p>
    <img class="ghost-mark" src={`${base}assets/kittenwiz_logo.webp`} alt="" aria-hidden="true" loading="lazy" decoding="async" />
  </section>

  <section class="shell team-grid" aria-label="Team members">
    <article class="team-card team-card--lead">
      <div class="team-card__meta">
        <span>01 / operator</span>
        <span>security research · writing</span>
      </div>
      <div class="team-card__image-wrap">
        <img src={`${base}assets/goobers.webp`} alt="Naees and Haku" loading="eager" decoding="async" />
      </div>
      <h2>Naees</h2>
      <p>I study how systems fail at the edges: web authorization, identity boundaries, cloud exposure, AI-assisted attack surfaces, and the small assumptions that grow into practical attack paths.</p>
      <div class="skill-list" aria-label="Naees skills and research interests">
        <span>Web exploitation</span>
        <span>API security</span>
        <span>Identity & access control</span>
        <span>Active Directory tradecraft</span>
        <span>Network penetration testing</span>
        <span>Wireless security</span>
        <span>Cloud exposure review</span>
        <span>AI / LLM security</span>
        <span>Adversarial AI testing</span>
        <span>Security automation</span>
        <span>Technical reporting</span>
      </div>
    </article>

    <article class="team-card team-card--haku">
      <div class="team-card__meta">
        <span>02 / canine division</span>
        <span>morale · incident response</span>
      </div>
      <div class="team-card__image-wrap">
        <img src={`${base}assets/haku.webp`} alt="Haku" loading="eager" decoding="async" />
      </div>
      <h2>Haku</h2>
      <p>Haku keeps the desk grounded: interrupts tunnel vision, enforces breaks, and performs suspicious-package inspection with admirable seriousness.</p>
      <div class="skill-list" aria-label="Haku skills">
        <span>Morale operations</span>
        <span>Walk scheduling</span>
        <span>Snack-driven triage</span>
        <span>Keyboard interruption</span>
        <span>Threat sniffing</span>
      </div>
    </article>
  </section>

  <section class="shell credential-section" aria-labelledby="certification-focus-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">certification focus</p>
        <h2 id="certification-focus-title">A learning map across web, infrastructure, AD, wireless, and AI security.</h2>
      </div>
    </div>
    <div class="credential-grid">
      <article class="credential-card">
        <span>CPTS · OSCP</span>
        <p>Infrastructure penetration testing, enumeration discipline, exploitation chains, privilege escalation, and report-ready findings.</p>
      </article>
      <article class="credential-card">
        <span>CWES · CWEE</span>
        <p>Web and API exploitation depth: authorization flaws, backend logic, custom techniques, and modern application attack surfaces.</p>
      </article>
      <article class="credential-card">
        <span>CAPE</span>
        <p>Active Directory attack paths, identity abuse, Kerberos/NTLM tradecraft, and enterprise post-exploitation thinking.</p>
      </article>
      <article class="credential-card">
        <span>CWPE</span>
        <p>Wireless assessment fundamentals, Wi-Fi attack methodology, and network-adjacent exposure review.</p>
      </article>
      <article class="credential-card">
        <span>COAE</span>
        <p>Offensive AI and LLM security: prompt abuse, agent workflows, adversarial testing, automation, and model-adjacent risk.</p>
      </article>
    </div>
  </section>

  <section class="shell contact-block">
    <div>
      <p class="eyebrow">secure contact</p>
      <h2>Open to collaboration and security engagement.</h2>
      <p>For sensitive correspondence, use the PGP key. For quick contact, email is listed in the footer and the contact page includes the current fingerprint.</p>
    </div>
    <a class="button button--primary" href={`${base}contact/`}>View contact details</a>
  </section>
</Layout>

---
import Layout from '../../components/Layout.astro';
import { site } from '../../data/site';
const base = import.meta.env.BASE_URL;

const engagementTypes = [
  {
    key: 'black',
    number: '01',
    title: 'Black-box test',
    access: 'External view',
    art: 'assets/engagements/black-box-attack-path.webp',
    summary: 'Tests what an attacker can learn and validate from the outside, using only the agreed scope and rules of engagement.',
    deliverables: ['Executive summary', 'Technical findings', 'Retest notes'],
    bestFor: 'Public attack surface, internet-facing apps, pre-launch checks, and unknown exposure.',
    detail: 'Black-box testing starts with minimal context. The work emphasizes discovery, attack-surface mapping, safe validation, evidence capture, and clear remediation guidance.',
    inputs: ['Scope and rules of engagement', 'Test window and contact path', 'No source or architecture required'],
    outputs: ['Executive and technical summary', 'Finding evidence and severity', 'Fix guidance and retest status'],
  },
  {
    key: 'grey',
    number: '02',
    title: 'Grey-box test',
    access: 'Limited context',
    art: 'assets/engagements/grey-box-scope-map.webp',
    summary: 'Combines attacker-style testing with selected internal context such as test accounts, roles, architecture notes, or API documentation.',
    deliverables: ['Findings report', 'Access-control review', 'Retest notes'],
    bestFor: 'Authenticated applications, role boundaries, APIs, multi-tenant flows, and business-logic testing.',
    detail: 'Grey-box testing is often the highest-signal model for product teams because it uses enough context to reach sensitive paths without losing adversarial thinking.',
    inputs: ['Test accounts and role matrix', 'Architecture or API notes', 'Representative workflows'],
    outputs: ['Abuse-case findings', 'Authorization and logic gaps', 'Prioritized remediation plan'],
  },
  {
    key: 'white',
    number: '03',
    title: 'White-box review',
    access: 'Full context',
    art: 'assets/engagements/white-box-code-review.webp',
    summary: 'Uses source, configuration, architecture, and implementation detail to trace issues deeply and reduce false positives.',
    deliverables: ['Code-aware findings', 'Root-cause notes', 'Remediation review'],
    bestFor: 'Critical systems, pre-release review, complex auth flows, source-assisted vulnerability research, and hard-to-reproduce issues.',
    detail: 'White-box review is best when the goal is depth: understanding why a weakness exists, where else it may appear, and how to fix it without creating regressions.',
    inputs: ['Source or repository access', 'Configuration and deployment notes', 'Security assumptions and design goals'],
    outputs: ['Root-cause analysis', 'Affected code paths', 'Patch and verification guidance'],
  },
];

const process = [
  ['01', 'Scope', 'Confirm assets, objectives, test window, rules of engagement, and emergency contacts.'],
  ['02', 'Map', 'Build an attack-surface view: entry points, roles, trust boundaries, and high-risk workflows.'],
  ['03', 'Test', 'Validate weaknesses safely, capture evidence, and avoid destructive actions unless explicitly approved.'],
  ['04', 'Report', 'Deliver executive and technical findings with severity, impact, evidence, and remediation guidance.'],
  ['05', 'Retest', 'Review fixes, update status, and close the loop with a concise validation note.'],
];

---

<Layout title="Engagements — NaeesSecurity" description="Scoped security testing, review, and advisory engagements from NaeesSecurity." pathname="/engagements/">
  <section class="ns-shell ns-page-header ns-engagement-hero">
    <div>
      <p class="ns-kicker">Services our team provides</p>
      <h1 class="ns-page-title">Engagements</h1>
      <p class="ns-subtitle">Scoped security testing and review for teams that need clear findings</p>
           <div class="ns-actions">
        <a class="ns-button ns-button-primary" href={`${base}contact/?subject=Security%20engagement%20request`}>Request scope discussion</a>
        <a class="ns-button" href="#engagement-types">Compare models</a>
      </div>
    </div>
    <aside class="ns-attack-terminal" aria-label="Simulated Linux terminal for an authorized engagement" data-attack-terminal>
      <div class="ns-attack-terminal__chrome">
        <span class="ns-attack-terminal__controls" aria-hidden="true">
          <span class="ns-terminal-dot ns-terminal-dot-close"></span>
          <span class="ns-terminal-dot ns-terminal-dot-minimize"></span>
          <span class="ns-terminal-dot ns-terminal-dot-fullscreen"></span>
        </span>
        <span class="ns-attack-terminal__title">naees@TargetBox: ~/engagement</span>
        <span class="ns-attack-terminal__mode">authorized dry-run</span>
      </div>
      <div class="ns-attack-terminal__screen" data-attack-terminal-screen aria-live="polite" aria-label="Authorized test-chain terminal output">
        <div class="ns-terminal-row ns-terminal-command">
          <span class="ns-terminal-prompt">naees@TargetBox:~$</span>
          <span class="ns-terminal-cursor" aria-hidden="true"></span>
        </div>
      </div>
    </aside>
    <script is:inline>
      (() => {
        const terminal = document.querySelector('[data-attack-terminal]');
        const screen = terminal?.querySelector('[data-attack-terminal-screen]');
        if (!terminal || !screen) return;

        const prompt = 'naees@TargetBox:~$';
        const steps = [
          {
            command: 'ns-engage plan --mode greybox --scope approved',
            output: [
              ['scope loaded: 3 apps · 2 roles · safe window confirmed', 'ok'],
              ['rules: non-destructive validation · emergency contact set', 'muted'],
            ],
          },
          {
            command: 'ns-map surface --passive --brief',
            output: [
              ['routes mapped · auth boundaries noted · metadata reviewed', 'muted'],
              ['priority paths: session, object access, report export', 'accent'],
            ],
          },
          {
            command: 'ns-test run --checks authz,session,workflow',
            output: [
              ['checks complete: 18 passed · 1 needs review', 'ok'],
              ['signal: authorization drift in report export path', 'warn'],
              ['impact: evidence captured · no destructive action taken', 'ok'],
            ],
          },
          {
            command: 'ns-report queue --format final',
            output: [
              ['finding queued · remediation path drafted · retest note pending', 'accent'],
              ['awaiting operator input...', 'muted'],
            ],
          },
        ];

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const sleep = (ms) => new Promise((resolve) => window.setTimeout(resolve, ms));
        const scrollToBottom = () => {
          screen.scrollTo({ top: screen.scrollHeight, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
        };
        const appendRow = (className) => {
          const row = document.createElement('div');
          row.className = className;
          screen.append(row);
          scrollToBottom();
          return row;
        };
        const appendPrompt = (isWaiting = false) => {
          const row = appendRow(`ns-terminal-row ns-terminal-command${isWaiting ? ' ns-terminal-awaiting' : ''}`);
          const promptNode = document.createElement('span');
          promptNode.className = 'ns-terminal-prompt';
          promptNode.textContent = prompt;
          const commandNode = document.createElement('span');
          commandNode.className = 'ns-terminal-typed';
          row.append(promptNode, document.createTextNode(' '), commandNode);
          if (isWaiting) {
            const cursor = document.createElement('span');
            cursor.className = 'ns-terminal-cursor';
            cursor.setAttribute('aria-hidden', 'true');
            row.append(cursor);
          }
          return commandNode;
        };
        const appendOutput = (text, tone = 'muted') => {
          const row = appendRow(`ns-terminal-row ns-terminal-output ns-terminal-output-${tone}`);
          row.textContent = `› ${text}`;
        };
        const typeCommand = async (command) => {
          const commandNode = appendPrompt(false);
          if (prefersReducedMotion) {
            commandNode.textContent = command;
            return;
          }
          for (const character of command) {
            commandNode.textContent += character;
            scrollToBottom();
            await sleep(22);
          }
        };
        const renderStatic = () => {
          screen.replaceChildren();
          for (const step of steps) {
            const commandNode = appendPrompt(false);
            commandNode.textContent = step.command;
            for (const [text, tone] of step.output) appendOutput(text, tone);
          }
          appendPrompt(true);
        };
        const run = async () => {
          screen.replaceChildren();
          terminal.classList.add('is-fading-in');
          sleep(360).then(() => terminal.classList.remove('is-fading-in'));

          for (const step of steps) {
            await typeCommand(step.command);
            await sleep(prefersReducedMotion ? 0 : 140);
            for (const [text, tone] of step.output) appendOutput(text, tone);
            await sleep(prefersReducedMotion ? 0 : 360);
          }

          appendPrompt(true);
          if (prefersReducedMotion) return;

          await sleep(11000);
          terminal.classList.add('is-fading-out');
          await sleep(460);
          screen.replaceChildren();
          screen.scrollTop = 0;
          terminal.classList.remove('is-fading-out');
          await sleep(120);
          run();
        };

        if (prefersReducedMotion) renderStatic();
        else run();
      })();
    </script>
  </section>

  <section class="ns-section-tight" id="engagement-types">
    <div class="ns-shell">
      <div class="ns-table-wrap ns-engagement-overview">
        <div class="ns-table-header"><h2>Engagement types</h2><span class="ns-meta">Access model · deliverables</span></div>
        <table class="ns-table">
          <thead><tr><th>Type</th><th>Best fit</th><th>Typical deliverables</th></tr></thead>
          <tbody>
            {engagementTypes.map((item) => (
              <tr>
                <td>
                  <div class="ns-engagement-type-cell">
                    <span class:list={['ns-engagement-type-icon', `ns-engagement-type-icon-${item.key}`]} aria-hidden="true">{item.number}</span>
                    <div>
                      <strong>{item.title}</strong>
                      <span>{item.access}</span>
                    </div>
                  </div>
                </td>
                <td>{item.summary}</td>
                <td><ul class="ns-chip-list">{item.deliverables.map((entry) => <li class="ns-chip">{entry}</li>)}</ul></td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="ns-deliverable-note">Deliverables are flexible and scoped to the engagement. The examples above are a baseline of likely outputs, not a fixed package; final reporting can include executive summaries, technical findings, evidence, remediation guidance, retest notes, or other artifacts that fit the work.</p>
      </div>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell">
      <div class="ns-table-header" style="padding-inline: 0; border: 0; box-shadow: none; background: transparent;">
        <h2>Model details</h2>
        <span class="ns-meta">What each access level changes</span>
      </div>
      <div class="ns-engagement-detail-grid">
        {engagementTypes.map((item) => (
          <article class:list={['ns-engagement-detail-card', `ns-engagement-detail-card-${item.key}`]}>
            <div class="ns-engagement-art" aria-hidden="true">
              <img src={`${base}${item.art}`} alt="" loading="lazy" decoding="async" />
            </div>
            <p class="ns-meta">{item.number} · {item.access}</p>
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
            <div class="ns-engagement-detail-columns">
              <div>
                <h4>Inputs</h4>
                <ul class="ns-mini-list">{item.inputs.map((entry) => <li><span>→</span><span>{entry}</span></li>)}</ul>
              </div>
              <div>
                <h4>Outputs</h4>
                <ul class="ns-mini-list">{item.outputs.map((entry) => <li><span>✓</span><span>{entry}</span></li>)}</ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell">
      <div class="ns-table-header" style="padding-inline: 0; border: 0; box-shadow: none; background: transparent;"><h2>Engagement process</h2><span class="ns-meta">NIST / OWASP-aligned flow</span></div>
      <div class="ns-process ns-process-linear">
        {process.map(([number, title, text]) => (
          <article class="ns-process-step">
            <b>{number}</b>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell ns-secure-contact-band">
      <div>
        <p class="ns-kicker">secure contact</p>
        <h2>Start with scope, permission, and a verified channel.</h2>
        <p>Send the target, preferred model, timeline, and constraints.</p>
      </div>
      <div class="ns-secure-contact-band__action"><a class="ns-button ns-button-primary" href={`${base}contact/?subject=Security%20engagement%20request`}>Contact securely</a></div>
    </div>
  </section>
</Layout>

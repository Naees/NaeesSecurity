---
import Layout from '../../components/Layout.astro';
import { site } from '../../data/site';
const base = import.meta.env.BASE_URL;

const engagements = [
  { type: 'Web security review', icon: '◎', deliverables: ['Findings report', 'Technical brief', 'Risk summary'], duration: '1–3 weeks', status: 'Scoped', summary: 'Application assessments, attack surface review, and exploitability analysis.' },
  { type: 'Identity and access review', icon: '♙', deliverables: ['Design review', 'Gap analysis', 'Recommendations'], duration: '1–3 weeks', status: 'Scoped', summary: 'IAM design review, privilege analysis, and access-control validation.' },
  { type: 'Cloud exposure review', icon: '☁', deliverables: ['Exposure map', 'Issue report', 'Remediation guide'], duration: '1–3 weeks', status: 'Scoped', summary: 'Cloud configuration review, exposure mapping, and misconfiguration analysis.' },
  { type: 'Research partnership', icon: '▧', deliverables: ['Research notes', 'PoC / validation', 'Co-authored write-up'], duration: 'Ongoing', status: 'Open', summary: 'Joint research, vulnerability analysis, and validation of emerging issues.' },
];

const process = [
  ['01', 'Intake', 'Scope discussion and requirements capture.'],
  ['02', 'Scope & Access', 'Define scope, goals, and secure access.'],
  ['03', 'Research & Analysis', 'Investigation, validation, and impact assessment.'],
  ['04', 'Report & Review', 'Deliver findings, review with your team.'],
  ['05', 'Handoff', 'Knowledge transfer and next steps.'],
];
---

<Layout title="Engagements — NaeesSecurity" description="Security-focused collaboration, research support, and practical review from NaeesSecurity." pathname="/engagements/">
  <section class="ns-shell ns-page-header">
    <div>
      <p class="ns-kicker">engagements</p>
      <h1 class="ns-page-title">Engagements</h1>
      <p class="ns-subtitle">Security-focused collaboration, research support, and practical review.</p>
      <p class="ns-lede">I work with teams and organizations on focused problems where security rigor, clear thinking, and confidentiality matter. The work is scoped, documented, and time-boxed.</p>
    </div>
    <aside class="ns-console" aria-label="Operator availability">
      <div class="ns-console-header"><span>Operator availability</span><span class="ns-console-status"><span class="ns-status-dot"></span> online</span></div>
      <dl class="ns-console-body">
        <div class="ns-ledger-row"><dt>availability</dt><dd>open to collaboration</dd></div>
        <div class="ns-ledger-row"><dt>model</dt><dd>project-based / retainer / research partnerships</dd></div>
        <div class="ns-ledger-row"><dt>location</dt><dd>{site.location}</dd></div>
        <div class="ns-ledger-row"><dt>response</dt><dd>usually within 24–72 hours</dd></div>
        <div class="ns-ledger-row"><dt>intake</dt><dd>selective, scoped, and confidentiality-first</dd></div>
      </dl>
    </aside>
  </section>

  <section class="ns-section-tight">
    <div class="ns-shell ns-grid ns-grid-sidebar-wide ns-align-start">
      <div>
        <div class="ns-table-wrap">
          <div class="ns-table-header"><h2>Engagement types</h2><span class="ns-meta">Deliverables · typical duration</span></div>
          <table class="ns-table">
            <thead><tr><th>Type</th><th>Deliverables</th><th>Typical duration</th></tr></thead>
            <tbody>
              {engagements.map((item) => (
                <tr>
                  <td><span class="ns-contact-icon" aria-hidden="true">{item.icon}</span><strong>{item.type}</strong><br /><span class="ns-text-muted">{item.summary}</span></td>
                  <td>{item.deliverables.map((entry) => <>{entry}<br /></>)}</td>
                  <td><span class:list={['ns-status', `ns-status-${item.status.toLowerCase()}`]}>{item.status}</span><br />{item.duration}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <section class="ns-section-tight" style="border-bottom: 0;">
          <div class="ns-table-header" style="padding-inline: 0; border: 0; box-shadow: none; background: transparent;"><h2>Engagement process</h2></div>
          <div class="ns-process">
            {process.map(([number, title, text]) => (
              <article class="ns-process-step">
                <b>{number}</b>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <div class="ns-alert">
          <span aria-hidden="true">▣</span>
          <p>Confidentiality is the default. NDAs are available on request. All engagement work is scoped, documented, and time-boxed.</p>
          <a class="ns-link-arrow" href={`${base}contact/`}>Contact securely</a>
        </div>
      </div>

      <aside class="ns-sidebar" aria-label="Engagement sidebar">
        <section class="ns-panel ns-panel-pad">
          <h2>Best fit</h2>
          <ul class="ns-mini-list">
            <li><span>01</span><span><b>Bounded problems</b><br />Clear scope, owner, and decision path.</span></li>
            <li><span>02</span><span><b>High-signal reviews</b><br />Architecture, exploitability, and validation over generic checklists.</span></li>
            <li><span>03</span><span><b>Research support</b><br />Reproduction, root cause analysis, and write-up assistance.</span></li>
          </ul>
        </section>
        <section class="ns-panel ns-panel-pad">
          <h2>Secure contact</h2>
          <dl>
            <div class="ns-stat-row"><dt>Email</dt><dd>{site.email}</dd></div>
            <div class="ns-stat-row"><dt>Signal</dt><dd>{site.signalHandle}</dd></div>
            <div class="ns-stat-row"><dt>PGP fp</dt><dd>{site.pgpFingerprint}</dd></div>
          </dl>
          <div class="ns-actions"><a class="ns-button ns-button-primary" href={`${base}contact/?subject=Security%20engagement%20request`}>Request an engagement</a></div>
        </section>
        <section class="ns-card">
          <div class="ns-fingerprint-card">
            <div class="ns-fingerprint-art" aria-hidden="true">⌁</div>
            <div>
              <h2 class="ns-card-title">Verified operator</h2>
              <p>Trust through transparency. Verify identity and contact details before sharing sensitive context.</p>
              <a class="ns-link-arrow" href={`${base}contact/`}>View verification</a>
            </div>
          </div>
        </section>
      </aside>
    </div>
  </section>
</Layout>

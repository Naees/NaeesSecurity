---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { formatDate, getReadingTime } from '../../lib/utils';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.filter((post) => !post.data.draft).map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — NaeesSecurity`} description={post.data.description} pathname={`/posts/${post.id}/`} type="article" publishedTime={post.data.date.toISOString()} pageClass="article-page">
  <article class="article shell-narrow">
    <header class="article__header">
      <a class="back-link" href={`${base}posts/`}>← NaeesSecurity</a>
      <p class="eyebrow">{formatDate(post.data.date)} · {getReadingTime(post.body)} min read</p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row">
        {post.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </header>
    <div class="article__body">
      <Content />
    </div>
  </article>
</Layout>

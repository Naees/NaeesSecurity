---
import { getCollection } from 'astro:content'
import { slugify, getReadingTime } from '../../lib/utils'
import Layout from '../../components/Layout.astro'
import GiscusComments from '../../components/GiscusComments.astro'

const base = import.meta.env.BASE_URL

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map(post => ({
    params: { slug: post.id },
  }))
}

const { slug } = Astro.params
const allPosts = await getCollection('posts')
const postEntry = allPosts.find(p => p.id === slug)
const post = postEntry?.data
const body = postEntry?.body

if (!post) {
  throw new Error('Post not found: ' + slug)
}
---

<Layout
  title={post.title + ' — NaeesWrites'}
  description={post.description}
  pathname={'/posts/' + slug + '/'}
  publishedTime={post.date.toISOString()}
  type="article"
>

<div class="container">

  <!-- Terminal: cat post -->
  <div class="prompt">
    <span class="dollar">$</span> naees@writes:~/blog$ cat posts/{slug}.md
  </div>
  <div class="divider" aria-hidden="true">~~~</div>

  <!-- Meta -->
  <div class="post-meta">
    {post.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    &nbsp;&nbsp;·&nbsp;&nbsp;{getReadingTime(postEntry!.body)} min read
  </div>

  <h1 style="font-size: 2rem; margin-top: 0.5rem; margin-bottom: 0.5rem;">{post.title}</h1>

  {post.tags && post.tags.length > 0 && (
    <div class="post-tags-inline">
      {post.tags.map(tag => (
        <a href={`${base}/tags/${slugify(tag)}/`}>#{tag}</a>
      ))}
    </div>
  )}

  <div class="divider" aria-hidden="true">~~~</div>

  <!-- Body -->
  <div style="font-size: 1.05rem; line-height: 1.8;">
    {body}
  </div>

  <div class="divider" aria-hidden="true">~~~</div>

  <!-- Comments -->
  <div class="prompt" style="margin-bottom: 1.5rem;">
    <span class="dollar">$</span> naees@writes:~/blog$ ./comments.sh
  </div>
  <div style="margin-top: 1rem;">
    <GiscusComments currentSlug={slug} />
  </div>

</div>

</Layout>

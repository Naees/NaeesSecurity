---
import Layout from '../../components/Layout.astro';
import { caseFilters, researchCases } from '../../data/research';
import { issueUrl, site } from '../../data/site';
const base = import.meta.env.BASE_URL;
const cases = researchCases;
---

<Layout title="Research — NaeesSecurity" description="Security research case notes, field notes, and reproducible observations by Naees." pathname="/research/">
  <section class="ns-section ns-section-top">
    <div class="ns-shell ns-grid ns-grid-sidebar ns-align-start">
      <div>
        <header class="ns-page-header ns-page-header-inline">
          <div>
            <p class="ns-kicker">research archive › case notes</p>
            <h1 class="ns-page-title">Research</h1>
            <p class="ns-lede">Case notes, field notes, and reproducible security observations. This archive includes research across web security, identity, cloud exposure, and practical exploitation.</p>
          </div>
          <div class="ns-schematic" aria-label="Exposure and trust-boundary schematic">
            <span class="ns-node ns-node-user">user</span>
            <span class="ns-node ns-node-app">app web</span>
            <span class="ns-node ns-node-api">api services</span>
            <span class="ns-node ns-node-idp">identity providers</span>
            <span class="ns-node ns-node-data">data stores</span>
            <span class="ns-node ns-node-cloud">cloud providers</span>
            <i class="ns-wire ns-wire-1"></i><i class="ns-wire ns-wire-2"></i><i class="ns-wire ns-wire-3"></i><i class="ns-wire ns-wire-4"></i><i class="ns-wire ns-wire-5"></i>
          </div>
        </header>

        <div style="padding-top: 1rem;">
          <div class="ns-tabs" role="group" aria-label="Case filters">
            {caseFilters.map((tab, index) => (
              <button class="ns-tab" type="button" aria-pressed={index === 0 ? 'true' : 'false'} data-case-filter={tab === 'All cases' ? 'all' : tab.toLowerCase()}>{tab}</button>
            ))}
          </div>

          <div class="ns-table-wrap">
            <table class="ns-table">
              <thead>
                <tr><th>Case ID</th><th>Subject</th><th>Surface</th><th>Status</th><th>Updated</th><th>Tags</th></tr>
              </thead>
              <tbody>
                {cases.map((item) => (
                  <tr data-case-row data-surface={item.surface.toLowerCase()} data-tags={item.tags.join(',')}>
                    <td><a class="ns-case-id" href={`${base}research/${item.slug}/`}>{item.id}</a></td>
                    <td>{item.subject}</td>
                    <td>{item.surface}</td>
                    <td><span class:list={['ns-status', `ns-status-${item.status.toLowerCase()}`]}>{item.status}</span></td>
                    <td class="ns-nowrap">{item.updated}</td>
                    <td><ul class="ns-chip-list">{item.tags.map((tag) => <li class="ns-chip">{tag}</li>)}</ul></td>
                  </tr>
                ))}
              </tbody>
            </table>
            <div class="ns-table-footer"><span data-case-count>Showing 1–{cases.length} of {cases.length} cases</span><span>Page 1 of 1</span></div>
          </div>
        </div>

        <section style="padding-top: 1.6rem;">
          <div class="ns-table-header" style="padding-inline: 0; border: 0; box-shadow: none; background: transparent;"><h2>Featured case notes</h2></div>
          <div class="ns-grid ns-grid-3">
            {cases.slice(0, 3).map((item) => (
              <a class="ns-card" href={`${base}research/${item.slug}/`} data-case-card data-surface={item.surface.toLowerCase()} data-tags={item.tags.join(',')}>
                <div class="ns-card-header"><span class="ns-meta">Case note</span><span class:list={['ns-status', `ns-status-${item.status.toLowerCase()}`]}>{item.status}</span></div>
                <h3 class="ns-card-title">{item.id}</h3>
                <p><strong>{item.subject}</strong></p>
                <p>{item.summary}</p>
                <ul class="ns-chip-list">{item.tags.map((tag) => <li class="ns-chip">{tag}</li>)}</ul>
                <span class="ns-link-arrow">Read note</span>
              </a>
            ))}
          </div>
        </section>
      </div>

      <aside class="ns-sidebar" aria-label="Research sidebar">
        <section class="ns-panel ns-panel-pad">
          <h2>Research scope</h2>
          <ul class="ns-mini-list">
            <li><span>◎</span><span><b>Web Security</b><br />applications, APIs, and infrastructure</span></li>
            <li><span>♙</span><span><b>Identity</b><br />authn, authz, idp, and access control</span></li>
            <li><span>☁</span><span><b>Cloud Exposure</b><br />configurations, data, and services</span></li>
            <li><span>⌖</span><span><b>Practical Exploitation</b><br />techniques, chains, and tradecraft</span></li>
          </ul>
        </section>
        <section class="ns-panel ns-panel-pad">
          <h2>Status legend</h2>
          <ul class="ns-mini-list">
            <li><span class="ns-status ns-status-active">Active</span><span>actively researching or monitoring</span></li>
            <li><span class="ns-status ns-status-analysis">Analysis</span><span>working findings and validation</span></li>
            <li><span class="ns-status ns-status-closed">Closed</span><span>documented and no longer active</span></li>
            <li><span class="ns-status ns-status-resolved">Resolved</span><span>fixed or mitigated on target</span></li>
          </ul>
        </section>
        <section class="ns-panel ns-panel-pad">
          <h2>Fingerprint</h2>
          <p class="ns-fingerprint">{site.pgpFingerprint}</p>
          <p class="ns-meta">Key ID: 0x48CCB80F</p>
        </section>
        <nav class="ns-panel ns-panel-pad ns-footer-links" aria-label="Research verification links">
          <a href={`${base}keys/publickey.naees.asc`}>PGP public key →</a>
          <a href={issueUrl} target="_blank" rel="noopener noreferrer">Report site issue →</a>
          <a href={site.signal} target="_blank" rel="noopener noreferrer">Signal contact →</a>
        </nav>
      </aside>
    </div>
  </section>

  <script>
    const filterButtons = Array.from(document.querySelectorAll('[data-case-filter]'));
    const caseRows = Array.from(document.querySelectorAll('[data-case-row]'));
    const caseCards = Array.from(document.querySelectorAll('[data-case-card]'));
    const caseCount = document.querySelector('[data-case-count]');

    function matchesCaseFilter(element, filter) {
      if (filter === 'all') return true;
      const surface = element.getAttribute('data-surface') || '';
      const tags = (element.getAttribute('data-tags') || '').split(',');
      if (filter === 'exploitation') return tags.some((tag) => ['ssrf', 'idor', 'redirect', 'token', 'rbac'].includes(tag));
      return surface === filter;
    }

    function applyCaseFilter(filter) {
      let visible = 0;
      for (const row of caseRows) {
        const matches = matchesCaseFilter(row, filter);
        row.hidden = !matches;
        if (matches) visible++;
      }
      for (const card of caseCards) card.hidden = !matchesCaseFilter(card, filter);
      for (const button of filterButtons) button.setAttribute('aria-pressed', String(button.getAttribute('data-case-filter') === filter));
      if (caseCount) caseCount.textContent = `Showing ${visible} of ${caseRows.length} cases`;
    }

    for (const button of filterButtons) {
      button.addEventListener('click', () => applyCaseFilter(button.getAttribute('data-case-filter') || 'all'));
    }
  </script>
</Layout>

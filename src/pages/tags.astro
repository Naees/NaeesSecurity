---
import { getCollection } from 'astro:content'
import { getAllTags, getTagCount, slugify } from '../lib/utils'
import Layout from '../components/Layout.astro'

const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const allTags = getAllTags(posts)
const tagCounts = getTagCount(posts)
---

<Layout
  title="Tags — NaeesWrites"
  description="Browse posts by tag."
  pathname="/tags/"
>

<div class="container">

  <!-- Terminal: find -->
  <div class="prompt">
    <span class="dollar">$</span> naees@writes:~/blog$ find . -name "*.md" -path "*/posts/*" | sort -u
  </div>
  <div class="divider" aria-hidden="true">~~~</div>

  <!-- Tag list — plain monospace text, no badges -->
  <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 3rem;">
    {allTags.map(tag => (
      <a href={`/tags/${slugify(tag)}/`} class="tag-link">
        {tag}<span class="tag-count">[{tagCounts.get(tag)}]</span>
      </a>
    ))}
  </div>

  <div class="divider" aria-hidden="true">~~~</div>

  <!-- Terminal: grep -->
  <div class="prompt" style="margin-bottom: 1.5rem;">
    <span class="dollar">$</span> naees@writes:~/blog$ grep -l "#" posts/*.md | sort -u
  </div>

  <!-- Tagged posts grouped by tag -->
  {allTags.map(tag => {
    const tagPosts = posts.filter(post =>
      (post.data.tags || []).map(t => slugify(t)).includes(slugify(tag))
    )
    if (tagPosts.length === 0) return null
    return (
      <div style="margin-bottom: 2.5rem;" role="region" aria-labelledby={`tag-${slugify(tag)}`}>
        <h2 id={`tag-${slugify(tag)}`} style="font-size: 1rem; margin-top: 0; margin-bottom: 1rem; color: var(--accent);">
          {tag}
          <span style="color: var(--text-dim); font-size: 0.8rem; margin-left: 0.5rem;">[{tagPosts.length}]</span>
        </h2>
        <ul style="list-style: none; padding: 0;">
          {tagPosts.map(post => (
            <li style="margin-bottom: 0.75rem; padding-left: 1rem; border-left: 1px solid var(--text-muted);">
              <a
                href={`/posts/${post.id}/`}
                style="text-decoration: none; color: var(--text);"
              >
                <span style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim); margin-right: 0.5rem;">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  })}

</div>

</Layout>

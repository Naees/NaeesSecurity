---
import '../styles/base.css';
import '../styles/blog.css';
import '../styles/ns-main.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import SeoHead from './SeoHead.astro';

interface Props {
  title: string;
  description: string;
  pathname: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  pageClass?: string;
  showScrollProgress?: boolean;
}

const {
  title,
  description,
  pathname,
  type = 'website',
  publishedTime,
  pageClass = '',
  showScrollProgress = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const isBlog = pathname.startsWith('/posts/');
const bodyClass = [!isBlog && 'ns-page', pageClass].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#070808" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate icon" href={`${base}favicon.ico`} />
    <link rel="alternate" type="application/rss+xml" title="NaeesSecurity RSS" href={`${base}rss.xml`} />
    <SeoHead title={title} description={description} pathname={pathname} type={type} publishedTime={publishedTime} />
  </head>
  <body class={bodyClass}>
    <a class={isBlog ? 'skip-link' : 'ns-skip'} href="#content">Skip to content</a>
    {showScrollProgress && <div class="scroll-progress" aria-hidden="true"><span></span></div>}
    <Header pathname={pathname} />
    <main id="content" class:list={[!isBlog && 'ns-main']}>
      <slot />
    </main>
    <Footer pathname={pathname} />
    {showScrollProgress && (
      <script>
        const root = document.documentElement;
        let scrollFrame = 0;

        function updateScrollProgress() {
          const scrollable = root.scrollHeight - window.innerHeight;
          const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
          const clampedProgress = Math.min(1, Math.max(0, progress));
          root.style.setProperty('--scroll-progress', String(clampedProgress));
          root.classList.toggle('is-scroll-complete', clampedProgress > 0.985);
          scrollFrame = 0;
        }

        function requestScrollProgress() {
          if (scrollFrame) return;
          scrollFrame = requestAnimationFrame(updateScrollProgress);
        }

        updateScrollProgress();
        window.addEventListener('scroll', requestScrollProgress, { passive: true });
        window.addEventListener('resize', requestScrollProgress, { passive: true });
      </script>
    )}
  </body>
</html>

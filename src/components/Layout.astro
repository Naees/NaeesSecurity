---
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import SeoHead from './SeoHead.astro';

interface Props {
  title: string;
  description: string;
  pathname: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  pageClass?: string;
}

const {
  title,
  description,
  pathname,
  type = 'website',
  publishedTime,
  pageClass = '',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#070808" />
    <link rel="icon" href={`${base}assets/kittenwiz_logo.webp`} />
    <link rel="alternate" type="application/rss+xml" title="NaeesSecurity RSS" href={`${base}rss.xml`} />
    <SeoHead title={title} description={description} pathname={pathname} type={type} publishedTime={publishedTime} />
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#content">Skip to content</a>
    <Header pathname={pathname} />
    <main id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
const currentYear = new Date().getFullYear()
const base = import.meta.env.BASE_URL
---

<footer style="padding: 3rem 0; border-top: 1px solid var(--border); margin-top: 4rem;">
  <div class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2.5rem; margin-bottom: 2.5rem;">
      <div>
        <h3 style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-secondary); margin-bottom: 1rem;">Navigate</h3>
        <ul style="list-style: none; padding: 0;">
          <li style="margin-bottom: 0.5rem;"><a href={`${base}/`} style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">Home</a></li>
          <li style="margin-bottom: 0.5rem;"><a href={`${base}/about/`} style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">About</a></li>
          <li style="margin-bottom: 0.5rem;"><a href={`${base}/tags/`} style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">Tags</a></li>
        </ul>
      </div>
      <div>
        <h3 style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-secondary); margin-bottom: 1rem;">Connect</h3>
        <ul style="list-style: none; padding: 0;">
          <li style="margin-bottom: 0.5rem;"><a href="https://github.com/Naees" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">GitHub</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="https://linkedin.com/in/seanejl" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">LinkedIn</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="https://x.com/NaeesWrites" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">X (formerly Twitter)</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="https://signal.me/#eu/pkPGfK8xQ3mJvR2wY1nL5tZ9cH4bE6dA0sU7iO3gW8k=" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">Signal</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="https://keybase.io/Naees/pgp_keys.asc" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">PGP Key</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="mailto:naees@protonmail.com" style="text-decoration: none; color: var(--text-secondary); font-size: 0.9rem;">naees@protonmail.com</a></li>
        </ul>
      </div>
    </div>
    <div style="padding-top: 1.5rem; border-top: 1px solid var(--border); font-size: 0.8rem; color: var(--text-secondary);">
      &copy; {currentYear} NaeesWrites. All rights reserved.
    </div>
  </div>
</footer>

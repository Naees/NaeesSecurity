---
import { site } from '../data/site';

interface Props { pathname: string }

const { pathname } = Astro.props;
const base = import.meta.env.BASE_URL;
const isBlog = pathname.startsWith('/posts/');
---

<footer class:list={['site-footer', isBlog && 'site-footer--blog']}>
  <div>
    <strong>{isBlog ? site.blogName : site.name}</strong>
    <p>{isBlog ? 'Essays, notes, and longer-form writing by Sean E.' : site.tagline}</p>
  </div>
  <nav aria-label="Footer links">
    {isBlog ? (
      <>
        <a href={`${base}posts/`}>All posts</a>
        <a href={`${base}rss.xml`}>RSS</a>
        <a href={base}>NaeesSecurity</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </>
    ) : (
      <>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={site.x} target="_blank" rel="noopener noreferrer">X</a>
        <a href={`${base}keys/publickey.naees.asc`}>PGP</a>
        <a href={`${base}rss.xml`}>RSS</a>
      </>
    )}
  </nav>
</footer>

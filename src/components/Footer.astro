---
import { site } from '../data/site';

interface Props { pathname: string }

const { pathname } = Astro.props;
const base = import.meta.env.BASE_URL;
const isBlog = pathname.startsWith('/posts/');
const issueUrl = 'https://github.com/Naees/NaeesSecurity/issues/new?title=Site%20issue%3A%20&body=Page%3A%0A%0AIssue%3A%0A%0AExpected%20behavior%3A%0A%0ABrowser%2Fdevice%3A';
---

<footer class:list={['site-footer', isBlog && 'site-footer--blog']}>
  <div class="site-footer__intro">
    <strong>{isBlog ? site.blogName : site.name}</strong>
    <p>{isBlog ? 'Security essays, notes, and longer-form writing' : site.tagline}</p>
    {isBlog && <p class="site-footer__fingerprint">Brought to you by NaeesSecurity.</p>}
    <p class="site-footer__notice">Send sensitive information through encrypted channels, check in contact for more information. </p>
  </div>
  <nav class="site-footer__links" aria-label="Footer links">
    {isBlog ? (
      <>
        <div>
          <span>Read</span>
          <a href={`${base}posts/`}>All posts</a>
          <a href={`${base}rss.xml`}>RSS</a>
        </div>
        <div>
          <span>Socials & Main Site</span>
          <a href={base}>NaeesSecurity</a>
          <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href={site.x} target="_blank" rel="noopener noreferrer">X / Twitter</a>
        </div>
        <div>
          <span>Contact</span>
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <a href={site.signal} target="_blank" rel="noopener noreferrer">Signal</a>
          <a href={`${base}keys/publickey.naees.asc`}>PGP</a>
          <a href={issueUrl} target="_blank" rel="noopener noreferrer">Report issue</a>
        </div>
      </>
    ) : (
      <>
        <div>
          <span>Verify</span>
          <a href={`${base}keys/`}>Fingerprint</a>
        </div>
        <div>
          <span>Socials & Blog</span>
          <a href={`${base}posts/`}>{site.blogName}</a>
          <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href={site.x} target="_blank" rel="noopener noreferrer">X / Twitter</a>
        </div>
        <div>
          <span>Contact</span>
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <a href={site.signal} target="_blank" rel="noopener noreferrer">Signal</a>
          <a href={`${base}keys/publickey.naees.asc`}>PGP key</a>
          <a href={issueUrl} target="_blank" rel="noopener noreferrer">Report issue</a>
        </div>
      </>
    )}
  </nav>
</footer>

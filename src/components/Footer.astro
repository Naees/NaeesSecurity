---
const currentYear = new Date().getFullYear()
---

<footer style="padding: 3rem 0; border-top: 1px solid var(--border); margin-top: 4rem;">
  <div class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2.5rem; margin-bottom: 2.5rem;">
      <div>
        <h3 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 1rem; font-family: var(--font-mono);">Navigate</h3>
        <ul style="list-style: none; padding: 0; font-family: var(--font-mono); font-size: 0.85rem;">
          <li style="margin-bottom: 0.5rem;"><a href="/" style="text-decoration: none; color: var(--text-secondary);">Home</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="/about/" style="text-decoration: none; color: var(--text-secondary);">About</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="/tags/" style="text-decoration: none; color: var(--text-secondary);">Tags</a></li>
        </ul>
      </div>
      <div>
        <h3 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 1rem; font-family: var(--font-mono);">Connect</h3>
        <ul style="list-style: none; padding: 0; font-family: var(--font-mono); font-size: 0.85rem;">
          <li style="margin-bottom: 0.5rem;"><a href="https://github.com/Naees" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary);">GitHub</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="https://linkedin.com/in/Naees" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary);">LinkedIn</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="https://twitter.com/Naees" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary);">X</a></li>
        </ul>
      </div>
      <div>
        <h3 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 1rem; font-family: var(--font-mono);">Resources</h3>
        <ul style="list-style: none; padding: 0; font-family: var(--font-mono); font-size: 0.85rem;">
          <li style="margin-bottom: 0.5rem;"><a href="/rss" style="text-decoration: none; color: var(--text-secondary);">RSS Feed</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="https://github.com/Naees/NaeesWrites" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-secondary);">Source Code</a></li>
        </ul>
      </div>
    </div>
    <div style="padding-top: 1.5rem; border-top: 1px solid var(--border); font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-secondary);">
      &copy; {currentYear} NaeesWrites. All rights reserved.
    </div>
  </div>
</footer>

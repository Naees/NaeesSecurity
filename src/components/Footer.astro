---
import { getFooterGroups, site } from '../data/site';

interface Props { pathname: string }

const { pathname } = Astro.props;
const base = import.meta.env.BASE_URL || '/';
const isBlog = pathname.startsWith('/posts/');
const footerGroups = getFooterGroups(base, isBlog);
---

<footer class:list={['site-footer', isBlog && 'site-footer--blog']}>
  <div class="site-footer__intro">
    <strong>{isBlog ? site.blogName : site.name}</strong>
    <p>{isBlog ? 'Security essays, notes, and longer-form writing' : site.tagline}</p>
    {isBlog && <p class="site-footer__fingerprint">Brought to you by NaeesSecurity.</p>}
  </div>
  <nav class="site-footer__links" aria-label="Footer links">
    {footerGroups.map((group) => (
      <div>
        <span>{group.label}</span>
        {group.links.map((link) => (
          <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener noreferrer' : undefined}>{link.label}</a>
        ))}
      </div>
    ))}
  </nav>
</footer>

---
interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props
const base = import.meta.env.BASE_URL
---

<header>
  <div class="container--wide" style="display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; padding-bottom: 1.5rem;">
    <a
      href={`${base}/`}
      class="nav-link"
      style="font-size: 0.9rem;"
    >
      naees@writes:~$
    </a>
    <nav aria-label="Main navigation" style="display: flex; align-items: center; gap: 1.5rem;">
      <a
        href={`${base}/`}
        class={`nav-link ${currentPage === '/' ? 'nav-link--active' : ''}`}
      >
        home
      </a>
      <a
        href={`${base}/about/`}
        class={`nav-link ${currentPage === '/about/' ? 'nav-link--active' : ''}`}
      >
        about
      </a>
      <a
        href={`${base}/tags/`}
        class={`nav-link ${currentPage === '/tags/' ? 'nav-link--active' : ''}`}
      >
        tags
      </a>
      <a
        href="https://github.com/Naees"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link"
        aria-label="GitHub"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <div class="dark-mode-toggle" role="button" tabindex="0" aria-label="Toggle dark mode">
        <span class="icon">
          <svg class="sun-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
        <span class="icon" style="display: none;">
          <svg class="moon-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
        <span class="label">dark</span>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.dark-mode-toggle') as HTMLElement
  const sunIcon = toggle?.querySelector('.sun-icon') as SVGElement
  const moonIcon = toggle?.querySelector('.moon-icon') as SVGElement
  const label = toggle?.querySelector('.label') as HTMLSpanElement

  function updateIcon() {
    const theme = localStorage.getItem('theme')
    const isDark = theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)
    if (isDark) {
      sunIcon!.style.display = 'none'
      moonIcon!.style.display = 'block'
      label!.textContent = 'dark'
    } else {
      sunIcon!.style.display = 'block'
      moonIcon!.style.display = 'none'
      label!.textContent = 'light'
    }
  }

  updateIcon()

  function handleClick() {
    const current = localStorage.getItem('theme')
    const next = current === 'dark' ? 'light' : 'dark'
    localStorage.setItem('theme', next)
    document.documentElement.setAttribute('data-theme', next)
    updateIcon()
  }

  toggle?.addEventListener('click', handleClick)
  toggle?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault()
      handleClick()
    }
  })
</script>

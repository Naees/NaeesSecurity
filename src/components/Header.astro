---
import { navLinks, site } from '../data/site';

interface Props { pathname: string }
const { pathname } = Astro.props;
const base = import.meta.env.BASE_URL;
const isBlog = pathname.startsWith('/posts/');
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class:list={['site-header', isBlog && 'site-header--blog']}>
  <a class="brand" href={isBlog ? `${base}posts/` : base} aria-label={isBlog ? `${site.blogName} home` : 'Naees home'}>
    <img src={`${base}assets/kittenwiz_logo.webp`} alt="" width="34" height="34" />
    <span class="brand__text"><strong>{isBlog ? site.blogName : site.headerName}</strong><em>{isBlog ? 'paper trail' : 'by sean e.'}</em></span>
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    {isBlog ? (
      <>
        <a class:list={[pathname === '/posts/' && 'is-active']} href={`${base}posts/`}>all posts</a>
        <a href={base}>← {site.name}</a>
      </>
    ) : navLinks.map((link) => (
      <a class:list={[isActive(link.href) && 'is-active']} href={`${base}${link.href.replace(/^\//, '')}`}>{link.label}</a>
    ))}
  </nav>
</header>

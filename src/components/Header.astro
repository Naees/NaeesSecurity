---
import BrandMark from './BrandMark.astro';
import { site } from '../data/site';

interface Props { pathname: string }
const { pathname } = Astro.props;
const base = import.meta.env.BASE_URL;
const isBlog = pathname.startsWith('/posts/');
const mainNav = [
  { href: '/', label: 'Home' },
  { href: '/posts/', label: site.blogName },
  { href: '/javalin/', label: 'Javalin' },
  { href: '/engagements/', label: 'Engagements' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

{isBlog ? (
  <header class="site-header site-header--blog">
    <a class="brand" href={`${base}posts/`} aria-label={`${site.blogName} home`}>
      <span class="brand__mark" aria-hidden="true"><BrandMark /></span>
      <span class="brand__text"><strong>{site.blogName}</strong><em>Security research & field notes</em></span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      <a class:list={[pathname === '/posts/' && 'is-active']} href={`${base}posts/`}>all posts</a>
      <a href={base}>← {site.name}</a>
    </nav>
  </header>
) : (
  <header class="ns-site-header">
    <nav class="ns-shell ns-nav" aria-label="Primary navigation">
      <a class="ns-brand" href={base} aria-label="NaeesSecurity home">
        <span class="ns-brand-mark" aria-hidden="true"><BrandMark /></span>
        <span class="ns-brand-text">
          <strong class="ns-brand-name">{site.headerName}</strong>
          <em class="ns-brand-tagline">We exploit the <span class="ns-footer-brand__unseen">unseen.</span></em>
        </span>
      </a>
      <ul class="ns-nav-links">
        {mainNav.map((link) => (
          <li><a aria-current={isActive(link.href) ? 'page' : undefined} href={`${base}${link.href.replace(/^\//, '')}`}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </header>
)}
